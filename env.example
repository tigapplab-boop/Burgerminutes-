/* =========================================================================
   Caisse & Pointage — Burger Minute
   Frontend vanilla JS — logique de l'application.
   ========================================================================= */

'use strict';

// --------------------------------------------------------------------------
// Utilitaires
// --------------------------------------------------------------------------

/** Formate un montant en DA avec séparateur de milliers. */
function fmtDA(n) {
  const v = Math.round(Number(n) || 0);
  return v.toLocaleString('fr-FR') + ' DA';
}

/** Date du jour au format YYYY-MM-DD (local). */
function todayStr() {
  const d = new Date();
  const tz = d.getTimezoneOffset() * 60000;
  return new Date(d - tz).toISOString().slice(0, 10);
}

/** Premier jour du mois courant. */
function firstOfMonthStr() {
  const d = new Date();
  const tz = d.getTimezoneOffset() * 60000;
  return new Date(d.getFullYear(), d.getMonth(), 1).toISOString().slice(0, 10);
}

/** Affiche un toast pendant ~2.5s. */
function toast(msg, type) {
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.className = 'toast' + (type ? ' ' + type : '');
  el.hidden = false;
  clearTimeout(toast._t);
  toast._t = setTimeout(() => { el.hidden = true; }, 2500);
}

/** Wrapper fetch qui renvoie du JSON et gère les erreurs 401. */
async function api(method, url, body) {
  const opt = { method, headers: { 'Content-Type': 'application/json' }, credentials: 'same-origin' };
  if (body !== undefined) opt.body = JSON.stringify(body);
  const res = await fetch(url, opt);
  if (res.status === 401) {
    // Session expirée — on bascule vers l'écran de connexion.
    showLogin();
    throw new Error('Non authentifié');
  }
  let data = null;
  try { data = await res.json(); } catch (e) { /* pas de body */ }
  if (!res.ok) throw new Error((data && data.error) || ('HTTP ' + res.status));
  return data;
}

// --------------------------------------------------------------------------
// Modale générique
// --------------------------------------------------------------------------

const modalRoot = document.getElementById('modal-root');
const modalTitle = document.getElementById('modal-title');
const modalBody = document.getElementById('modal-body');
const modalCancel = document.getElementById('modal-cancel');
const modalOk = document.getElementById('modal-ok');
let modalResolve = null;

/** Affiche une modale avec un HTML body donné. Renvoie une promesse :
 *  - true si l'utilisateur a cliqué OK
 *  - false s'il a cliqué Annuler ou sur le backdrop */
function openModal(title, bodyHTML, okLabel, cancelLabel) {
  modalTitle.textContent = title;
  modalBody.innerHTML = bodyHTML;
  modalOk.textContent = okLabel || 'OK';
  modalCancel.textContent = cancelLabel || 'Annuler';
  modalRoot.hidden = false;
  return new Promise((resolve) => { modalResolve = resolve; });
}
function closeModal(val) {
  modalRoot.hidden = true;
  modalBody.innerHTML = '';
  if (modalResolve) { modalResolve(val); modalResolve = null; }
}
modalOk.addEventListener('click', () => closeModal(true));
modalCancel.addEventListener('click', () => closeModal(false));
document.querySelector('.modal-backdrop').addEventListener('click', () => closeModal(false));

// --------------------------------------------------------------------------
// État global côté client
// --------------------------------------------------------------------------

const state = {
  settings: { fond: 0, charges: 0 },
  workers: [],
  entries: {},           // entrées déjà chargées (cache)
  currentEntry: null,    // entrée de la journée en cours d'édition
  finance: { workers: [], bilan: null, suppliers: [], tx: [] }
};

// --------------------------------------------------------------------------
// Affichage écran login vs app
// --------------------------------------------------------------------------

const loginScreen = document.getElementById('login-screen');
const appEl = document.getElementById('app');

function showLogin() {
  loginScreen.hidden = false;
  appEl.hidden = true;
}
function showApp(user) {
  loginScreen.hidden = true;
  appEl.hidden = false;
  document.getElementById('topbar-user').textContent = user ? ('· ' + user) : '';
  // Initialise les onglets
  switchTab('jour');
  // Charge les réglages + workers + historique
  loadSettings();
  loadWorkers();
  loadHistory();
  // Pré-remplit la date du jour
  document.getElementById('jour-date').value = todayStr();
  loadJour();
}

// --------------------------------------------------------------------------
// Auth
// --------------------------------------------------------------------------

document.getElementById('login-form').addEventListener('submit', async (e) => {
  e.preventDefault();
  const username = document.getElementById('login-user').value.trim();
  const password = document.getElementById('login-pass').value;
  const errEl = document.getElementById('login-error');
  errEl.hidden = true;
  try {
    const r = await api('POST', '/api/login', { username, password });
    errEl.hidden = true;
    const me = await api('GET', '/api/me');
    if (me.authed) showApp(me.user);
  } catch (err) {
    errEl.textContent = err.message || 'Connexion impossible';
    errEl.hidden = false;
  }
});

document.getElementById('logout-btn').addEventListener('click', async () => {
  await api('POST', '/api/logout');
  showLogin();
});

// Au chargement : vérifie si on a déjà une session
(async function init() {
  try {
    const me = await api('GET', '/api/me');
    if (me.authed) showApp(me.user);
    else showLogin();
  } catch (e) {
    showLogin();
  }
})();

// --------------------------------------------------------------------------
// Navigation entre onglets
// --------------------------------------------------------------------------

document.querySelectorAll('.nav-btn').forEach((btn) => {
  btn.addEventListener('click', () => switchTab(btn.dataset.tab));
});

function switchTab(name) {
  document.querySelectorAll('.nav-btn').forEach((b) => b.classList.toggle('active', b.dataset.tab === name));
  document.querySelectorAll('.tab-content').forEach((t) => { t.hidden = true; });
  document.getElementById('tab-' + name).hidden = false;
  if (name === 'finances') loadFinances();
  if (name === 'historique') loadHistory();
  if (name === 'reglages') loadReglages();
}

// --------------------------------------------------------------------------
// Onglet JOUR
// --------------------------------------------------------------------------

const jourDate = document.getElementById('jour-date');
jourDate.addEventListener('change', loadJour);
jourDate.max = todayStr();

async function loadSettings() {
  try {
    state.settings = await api('GET', '/api/settings');
  } catch (e) { toast('Réglages indisponibles', 'error'); }
}

async function loadWorkers() {
  try {
    state.workers = await api('GET', '/api/workers');
  } catch (e) { toast('Employés indisponibles', 'error'); }
  // Si on est sur l'onglet jour, on re-render.
  if (!document.getElementById('tab-jour').hidden) renderJourWorkers();
}

async function loadJour() {
  const date = jourDate.value;
  if (!date) return;
  try {
    state.currentEntry = await api('GET', '/api/entries/' + date);
    renderJour();
  } catch (e) {
    toast('Impossible de charger la journée', 'error');
  }
}

function renderJour() {
  renderJourWorkers();
  const e = state.currentEntry;
  document.getElementById('jour-caisseFin').value = e ? (e.caisseFin || '') : '';
  document.getElementById('jour-depenses').value = e ? (e.depenses || '') : '';
  updateResume();
}

function renderJourWorkers() {
  const wrap = document.getElementById('jour-workers');
  if (!state.workers.length) {
    wrap.innerHTML = '<p class="empty">Aucun employé configuré. Ajoutez-en dans l’onglet Réglages.</p>';
    return;
  }
  const entry = state.currentEntry || { workers: {} };
  wrap.innerHTML = state.workers.map((w) => {
    const wd = entry.workers[String(w.id)] || { present: false, montant: w.rate, retrait: 0 };
    return `
      <div class="worker-row" data-wid="${w.id}">
        <input type="checkbox" class="wk-present" ${wd.present ? 'checked' : ''} />
        <div class="worker-info">
          <span class="worker-name">${escapeHtml(w.name)}</span>
          <div class="worker-fields">
            <label>Salaire du jour (DA)
              <input type="number" class="wk-montant" min="0" step="100" inputmode="numeric"
                     value="${wd.montant ?? w.rate}" ${wd.present ? '' : 'disabled'} />
            </label>
            <label>Retrait (DA)
              <input type="number" class="wk-retrait" min="0" step="100" inputmode="numeric"
                     value="${wd.retrait || 0}" ${wd.present ? '' : 'disabled'} />
            </label>
          </div>
        </div>
      </div>`;
  }).join('');

  // Listeners sur chaque ligne
  wrap.querySelectorAll('.worker-row').forEach((row) => {
    const wid = row.dataset.wid;
    const cb = row.querySelector('.wk-present');
    const inpM = row.querySelector('.wk-montant');
    const inpR = row.querySelector('.wk-retrait');
    cb.addEventListener('change', () => {
      // À l'activation, on pré-remplit le montant avec le taux par défaut si vide.
      if (cb.checked && !inpM.value) {
        const w = state.workers.find((x) => String(x.id) === wid);
        if (w) inpM.value = w.rate;
      }
      inpM.disabled = !cb.checked;
      inpR.disabled = !cb.checked;
      if (!cb.checked) { inpM.value = ''; inpR.value = 0; }
      updateResume();
    });
    inpM.addEventListener('input', updateResume);
    inpR.addEventListener('input', updateResume);
  });
}

function collectJourFromDOM() {
  const wrap = document.getElementById('jour-workers');
  const workers = {};
  wrap.querySelectorAll('.worker-row').forEach((row) => {
    const wid = row.dataset.wid;
    const present = row.querySelector('.wk-present').checked;
    const montant = Number(row.querySelector('.wk-montant').value) || 0;
    const retrait = Number(row.querySelector('.wk-retrait').value) || 0;
    workers[wid] = { present, montant, retrait };
  });
  const caisseFin = Number(document.getElementById('jour-caisseFin').value) || 0;
  const depenses = Number(document.getElementById('jour-depenses').value) || 0;
  return { caisseFin, depenses, workers };
}

/** Recalcule la recette et le bénéfice à partir des champs du DOM. */
function updateResume() {
  const entry = collectJourFromDOM();
  const fond = Number(state.settings.fond) || 0;
  const charges = Number(state.settings.charges) || 0;
  const retraits = Object.values(entry.workers).reduce((a, w) => a + (Number(w.retrait) || 0), 0);
  // recette = caisseFin − fond + dépenses + Σ retraits
  const recette = entry.caisseFin - fond + entry.depenses + retraits;
  // benefice = recette − dépenses − charges
  const benefice = recette - entry.depenses - charges;

  document.getElementById('resume-recette').textContent = fmtDA(recette);
  document.getElementById('resume-charges').textContent = fmtDA(charges);
  const bEl = document.getElementById('resume-benefice');
  bEl.textContent = fmtDA(benefice);
  bEl.classList.toggle('neg', benefice < 0);
}

document.getElementById('jour-caisseFin').addEventListener('input', updateResume);
document.getElementById('jour-depenses').addEventListener('input', updateResume);

document.getElementById('jour-save').addEventListener('click', async () => {
  const date = jourDate.value;
  if (!date) { toast('Choisissez une date', 'error'); return; }
  const payload = collectJourFromDOM();
  const btn = document.getElementById('jour-save');
  btn.disabled = true; btn.textContent = 'Enregistrement…';
  const statusEl = document.getElementById('jour-status');
  try {
    await api('PUT', '/api/entries/' + date, payload);
    statusEl.hidden = false;
    statusEl.className = 'status-msg ok';
    statusEl.textContent = 'Journée enregistrée ✓';
    toast('Journée enregistrée', 'success');
    setTimeout(() => { statusEl.hidden = true; }, 3000);
  } catch (e) {
    statusEl.hidden = false;
    statusEl.className = 'status-msg err';
    statusEl.textContent = 'Erreur : ' + e.message;
  } finally {
    btn.disabled = false; btn.textContent = 'Enregistrer cette journée';
  }
});

// --------------------------------------------------------------------------
// Onglet HISTORIQUE
// --------------------------------------------------------------------------

async function loadHistory() {
  const wrap = document.getElementById('historique-list');
  try {
    const list = await api('GET', '/api/history');
    if (!list.length) {
      wrap.innerHTML = '<p class="empty">Aucune journée enregistrée pour le moment.</p>';
      return;
    }
    wrap.innerHTML = list.map((h) => {
      const benClass = h.benefice < 0 ? 'neg' : 'pos';
      return `
        <div class="history-item" data-date="${h.date}">
          <div>
            <div class="history-date">${formatDateFr(h.date)}</div>
            <div class="history-meta">Recette : ${fmtDA(h.recette)} · Retraits : ${fmtDA(h.retraits)}</div>
          </div>
          <div class="history-amount ${benClass}">${fmtDA(h.benefice)}</div>
        </div>`;
    }).join('');
    wrap.querySelectorAll('.history-item').forEach((item) => {
      item.addEventListener('click', () => {
        jourDate.value = item.dataset.date;
        switchTab('jour');
        loadJour();
      });
    });
  } catch (e) {
    wrap.innerHTML = '<p class="empty">Erreur de chargement.</p>';
  }
}

function formatDateFr(iso) {
  const [y, m, d] = iso.split('-').map(Number);
  const dt = new Date(y, m - 1, d);
  return dt.toLocaleDateString('fr-FR', { weekday: 'short', day: '2-digit', month: 'long', year: 'numeric' });
}

// --------------------------------------------------------------------------
// Onglet FINANCES
// --------------------------------------------------------------------------

const finStart = document.getElementById('fin-start');
const finEnd = document.getElementById('fin-end');
finStart.value = firstOfMonthStr();
finEnd.value = todayStr();

document.getElementById('fin-refresh').addEventListener('click', loadFinances);

async function loadFinances() {
  const start = finStart.value;
  const end = finEnd.value;
  if (!start || !end) { toast('Sélectionnez une période', 'error'); return; }

  // 1. Employés
  try {
    const workers = await api('GET', '/api/finance/workers?start=' + encodeURIComponent(start) + '&end=' + encodeURIComponent(end));
    renderFinWorkers(workers);
  } catch (e) { /* ignore */ }

  // 2. Fournisseurs + transactions
  try {
    const suppliers = await api('GET', '/api/suppliers');
    state.finance.suppliers = suppliers;
    renderFinSuppliers(suppliers);
  } catch (e) { /* ignore */ }
  try {
    const tx = await api('GET', '/api/supplier-tx');
    state.finance.tx = tx;
    renderFinTx(tx);
  } catch (e) { /* ignore */ }

  // 3. Bilan
  try {
    const bilan = await api('GET', '/api/finance/bilan?start=' + encodeURIComponent(start) + '&end=' + encodeURIComponent(end));
    renderBilan(bilan);
  } catch (e) { /* ignore */ }
}

function renderFinWorkers(workers) {
  const wrap = document.getElementById('fin-workers');
  if (!workers.length) {
    wrap.innerHTML = '<p class="empty">Aucun employé sur cette période.</p>';
    return;
  }
  let totalDu = 0, totalRetraits = 0, totalSolde = 0;
  workers.forEach((w) => { totalDu += w.salaireDu; totalRetraits += w.retraits; totalSolde += w.solde; });
  wrap.innerHTML = `
    <table class="fin-table">
      <thead>
        <tr><th>Employé</th><th>Jours</th><th>Salaire dû</th><th>Retraits</th><th>Solde</th></tr>
      </thead>
      <tbody>
        ${workers.map((w) => `
          <tr>
            <td>${escapeHtml(w.name)}</td>
            <td>${w.joursTravailles}</td>
            <td>${fmtDA(w.salaireDu)}</td>
            <td>${fmtDA(w.retraits)}</td>
            <td class="${w.solde < 0 ? 'neg' : 'pos'}">${fmtDA(w.solde)}</td>
          </tr>`).join('')}
      </tbody>
      <tfoot>
        <tr>
          <td>Totaux</td>
          <td></td>
          <td>${fmtDA(totalDu)}</td>
          <td>${fmtDA(totalRetraits)}</td>
          <td class="${totalSolde < 0 ? 'neg' : 'pos'}">${fmtDA(totalSolde)}</td>
        </tr>
      </tfoot>
    </table>
    <p style="margin-top:8px;font-size:12px;color:var(--gris);">
      Solde <strong>positif</strong> = à verser à l’employé · Solde <strong>négatif</strong> = l’employé doit de l’argent.
    </p>`;
}

function renderFinSuppliers(suppliers) {
  const wrap = document.getElementById('fin-suppliers');
  if (!suppliers.length) {
    wrap.innerHTML = '<p class="empty">Aucun fournisseur enregistré.</p>';
    return;
  }
  wrap.innerHTML = suppliers.map((s) => `
    <div class="supplier-row" data-sid="${s.id}">
      <div>
        <div class="supplier-name">${escapeHtml(s.name)}</div>
      </div>
      <div class="supplier-actions">
        <span class="supplier-dette ${s.dette !== 0 ? 'pos' : ''}">${fmtDA(s.dette)}</span>
        <button class="btn btn-tiny" data-action="del-sup">Supprimer</button>
      </div>
    </div>`).join('');
  wrap.querySelectorAll('.supplier-row').forEach((row) => {
    row.querySelector('[data-action="del-sup"]').addEventListener('click', async () => {
      const sid = Number(row.dataset.sid);
      const ok = await openModal('Supprimer ce fournisseur ?',
        '<p>Cela supprimera aussi <strong>toutes ses transactions</strong>. Action irréversible.</p>',
        'Supprimer', 'Annuler');
      if (!ok) return;
      try {
        await api('DELETE', '/api/suppliers/' + sid);
        toast('Fournisseur supprimé', 'success');
        loadFinances();
      } catch (e) { toast(e.message, 'error'); }
    });
  });
}

function renderFinTx(tx) {
  const wrap = document.getElementById('fin-tx');
  if (!tx.length) {
    wrap.innerHTML = '<p class="empty">Aucune transaction.</p>';
    return;
  }
  wrap.innerHTML = tx.map((t) => `
    <div class="tx-row" data-tid="${t.id}">
      <div class="tx-left">
        <span class="tx-supplier">${escapeHtml(t.supplierName)}</span>
        <span class="tx-meta">${formatDateFr(t.date)}</span>
        ${t.note ? `<span class="tx-note">${escapeHtml(t.note)}</span>` : ''}
      </div>
      <div class="tx-amount ${t.amount > 0 ? 'pos' : 'neg'}">
        ${t.amount > 0 ? '+' : ''}${fmtDA(t.amount)}
        <button class="btn btn-tiny" data-action="del-tx" style="margin-left:8px;">✕</button>
      </div>
    </div>`).join('');
  wrap.querySelectorAll('.tx-row').forEach((row) => {
    row.querySelector('[data-action="del-tx"]').addEventListener('click', async () => {
      const tid = Number(row.dataset.tid);
      const ok = await openModal('Supprimer cette transaction ?', '', 'Supprimer', 'Annuler');
      if (!ok) return;
      try {
        await api('DELETE', '/api/supplier-tx/' + tid);
        toast('Transaction supprimée', 'success');
        loadFinances();
      } catch (e) { toast(e.message, 'error'); }
    });
  });
}

function renderBilan(bilan) {
  document.getElementById('bilan-cumule').textContent = fmtDA(bilan.beneficeCumule);
  document.getElementById('bilan-dette').textContent = fmtDA(bilan.detteTotal);
  const sEl = document.getElementById('bilan-soldes');
  sEl.textContent = fmtDA(bilan.sommeSoldes);
  sEl.classList.toggle('neg', bilan.sommeSoldes < 0);
  const nEl = document.getElementById('bilan-net');
  nEl.textContent = fmtDA(bilan.beneficeNet);
  nEl.classList.toggle('neg', bilan.beneficeNet < 0);
}

// Boutons "Ajouter fournisseur" / "Nouvelle transaction"
document.getElementById('sup-add').addEventListener('click', async () => {
  const body = `
    <label><span>Nom du fournisseur</span>
      <input type="text" id="m-sup-name" placeholder="Ex : Boucherie X" />
    </label>`;
  const ok = await openModal('Nouveau fournisseur', body, 'Ajouter', 'Annuler');
  if (!ok) return;
  const name = document.getElementById('m-sup-name').value.trim();
  if (!name) { toast('Nom requis', 'error'); return; }
  try {
    await api('POST', '/api/suppliers', { name });
    toast('Fournisseur ajouté', 'success');
    loadFinances();
  } catch (e) { toast(e.message, 'error'); }
});

document.getElementById('tx-add').addEventListener('click', async () => {
  if (!state.finance.suppliers.length) {
    toast('Ajoutez d’abord un fournisseur', 'error');
    return;
  }
  const today = todayStr();
  const opts = state.finance.suppliers.map((s) => `<option value="${s.id}">${escapeHtml(s.name)}</option>`).join('');
  const body = `
    <label><span>Fournisseur</span>
      <select id="m-tx-sup">${opts}</select>
    </label>
    <label><span>Date</span>
      <input type="date" id="m-tx-date" value="${today}" />
    </label>
    <label><span>Montant (DA) — positif pour un achat à crédit, négatif pour un remboursement</span>
      <input type="number" id="m-tx-amount" step="100" inputmode="numeric" />
    </label>
    <label><span>Note (optionnel)</span>
      <input type="text" id="m-tx-note" placeholder="Ex : Achat viande" />
    </label>`;
  const ok = await openModal('Nouvelle transaction', body, 'Ajouter', 'Annuler');
  if (!ok) return;
  const supplierId = Number(document.getElementById('m-tx-sup').value);
  const date = document.getElementById('m-tx-date').value;
  const amount = Number(document.getElementById('m-tx-amount').value);
  const note = document.getElementById('m-tx-note').value.trim();
  if (!date || isNaN(amount)) { toast('Champs invalides', 'error'); return; }
  try {
    await api('POST', '/api/supplier-tx', { supplierId, date, amount, note });
    toast('Transaction ajoutée', 'success');
    loadFinances();
  } catch (e) { toast(e.message, 'error'); }
});

// --------------------------------------------------------------------------
// Onglet RÉGLAGES
// --------------------------------------------------------------------------

async function loadReglages() {
  try {
    const s = await api('GET', '/api/settings');
    document.getElementById('set-fond').value = s.fond;
    document.getElementById('set-charges').value = s.charges;
    state.settings = s;
  } catch (e) { toast(e.message, 'error'); }
  try {
    state.workers = await api('GET', '/api/workers');
    renderReglagesWorkers();
  } catch (e) { /* ignore */ }
}

function renderReglagesWorkers() {
  const wrap = document.getElementById('set-workers');
  if (!state.workers.length) {
    wrap.innerHTML = '<p class="empty">Aucun employé. Ajoutez-en ci-dessus.</p>';
    return;
  }
  wrap.innerHTML = state.workers.map((w) => `
    <div class="wk-row" data-wid="${w.id}">
      <input type="text" class="wk-name" value="${escapeHtml(w.name)}" />
      <input type="number" class="wk-rate" value="${w.rate}" min="0" step="100" inputmode="numeric" />
      <button class="btn btn-tiny" data-action="del">✕</button>
    </div>`).join('');
  wrap.querySelectorAll('.wk-row').forEach((row) => {
    const wid = Number(row.dataset.wid);
    row.querySelector('.wk-name').addEventListener('change', async (e) => {
      try { await api('PUT', '/api/workers/' + wid, { name: e.target.value.trim() }); toast('Enregistré'); }
      catch (err) { toast(err.message, 'error'); }
    });
    row.querySelector('.wk-rate').addEventListener('change', async (e) => {
      try { await api('PUT', '/api/workers/' + wid, { rate: Number(e.target.value) || 0 }); toast('Enregistré'); }
      catch (err) { toast(err.message, 'error'); }
    });
    row.querySelector('[data-action="del"]').addEventListener('click', async () => {
      const ok = await openModal('Supprimer cet employé ?',
        '<p>Ses pointages passés seront aussi supprimés des journées enregistrées.</p>',
        'Supprimer', 'Annuler');
      if (!ok) return;
      try {
        await api('DELETE', '/api/workers/' + wid);
        toast('Employé supprimé', 'success');
        loadReglages();
      } catch (err) { toast(err.message, 'error'); }
    });
  });
}

document.getElementById('set-save').addEventListener('click', async () => {
  const fond = Number(document.getElementById('set-fond').value) || 0;
  const charges = Number(document.getElementById('set-charges').value) || 0;
  try {
    state.settings = await api('PUT', '/api/settings', { fond, charges });
    toast('Réglages enregistrés', 'success');
    updateResume();
  } catch (e) { toast(e.message, 'error'); }
});

document.getElementById('wk-add').addEventListener('click', async () => {
  const body = `
    <label><span>Nom de l’employé</span>
      <input type="text" id="m-wk-name" placeholder="Ex : Yacine" />
    </label>
    <label><span>Taux journalier par défaut (DA)</span>
      <input type="number" id="m-wk-rate" value="2000" min="0" step="100" inputmode="numeric" />
    </label>`;
  const ok = await openModal('Nouvel employé', body, 'Ajouter', 'Annuler');
  if (!ok) return;
  const name = document.getElementById('m-wk-name').value.trim();
  const rate = Number(document.getElementById('m-wk-rate').value) || 0;
  if (!name) { toast('Nom requis', 'error'); return; }
  try {
    await api('POST', '/api/workers', { name, rate });
    toast('Employé ajouté', 'success');
    loadReglages();
  } catch (e) { toast(e.message, 'error'); }
});

// --------------------------------------------------------------------------
// Petite helper anti-XSS
// --------------------------------------------------------------------------

function escapeHtml(s) {
  return String(s)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}
