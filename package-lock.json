# --- Identifiants admin (gérant) ---
# Nom d'utilisateur utilisé pour se connecter à l'application.
ADMIN_USER=admin

# Mot de passe du gérant. CHOISISSEZ UN MOT DE PASSE FORT (>= 12 caractères,
# mélangeant majuscules/minuscules/chiffres/symboles). Ne le committez jamais.
ADMIN_PASSWORD=ChangezMoi!

# Secret utilisé pour signer le cookie de session.
# Générez une chaîne aléatoire longue, par exemple avec :
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=remplacez-par-une-chaine-aleatoire-longue

# Port d'écoute du serveur (Coolify le surcharge automatiquement via son proxy).
PORT=3000
